[
  {
    "type": "graphql",
    "id": "gql:platform-api",
    "url": "https://api.example.com/graphql",
    "query": "{ __typename }",
    "authEnvVar": "GRAPHQL_TOKEN",
    "authHeader": "Authorization",
    "required": true
  },
  {
    "type": "grpc",
    "id": "grpc:health",
    "target": "grpc.example.com:443",
    "method": "grpc.health.v1.Health/Check",
    "data": { "service": "" },
    "plaintext": false,
    "required": true
  },
  {
    "type": "sql",
    "id": "sql:orders",
    "connectionEnvVar": "ORDERS_DB_URL",
    "query": "select 1 as ok",
    "expectedMinRows": 1
  },
  {
    "type": "kafka",
    "id": "kafka:orders-topic",
    "brokersEnvVar": "KAFKA_BROKERS",
    "topic": "integrax.orders",
    "clientId": "integrax-surface-check-prod",
    "saslUsernameEnvVar": "KAFKA_SASL_USERNAME",
    "saslPasswordEnvVar": "KAFKA_SASL_PASSWORD",
    "required": true
  },
  {
    "type": "cdc",
    "id": "cdc:orders-connector",
    "url": "http://debezium:8083/connectors/orders-connector/status",
    "expectedConnectorState": "RUNNING",
    "expectedTaskState": "RUNNING",
    "required": true
  },
  {
    "type": "webhook",
    "id": "webhook:orders-ingress",
    "url": "https://api.example.com/webhooks/orders",
    "method": "POST",
    "expectedStatus": 200,
    "hmacSecretEnvVar": "WEBHOOK_SECRET",
    "signatureHeader": "X-Signature",
    "signaturePrefix": "sha256=",
    "required": true
  },
  {
    "type": "redis",
    "id": "redis:cache",
    "urlEnvVar": "REDIS_URL",
    "required": true
  }
]
