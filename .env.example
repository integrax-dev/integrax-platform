# ============================================
# INTEGRAX - Variables de Entorno
# ============================================
# Copia este archivo a .env y completá los valores

# --------------------------------------------
# Infraestructura (Docker)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=integrax
POSTGRES_PASSWORD=integrax
POSTGRES_DB=integrax

# --------------------------------------------
# MercadoPago
# --------------------------------------------
# Obtener de: https://www.mercadopago.com.ar/developers/panel/app
# Usá las credenciales de PRUEBA (sandbox) para testing
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxx

# --------------------------------------------
# Google Sheets (opcional)
# --------------------------------------------
# Opción 1: Service Account JSON (una sola línea, sin saltos)
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}

# Opción 2: OAuth2 Access Token (expira en 1 hora)
# GOOGLE_SHEETS_ACCESS_TOKEN=ya29.xxxxx

# Spreadsheet ID para pruebas (la parte de la URL después de /d/)
# GOOGLE_SHEETS_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms

# --------------------------------------------
# Worker
# --------------------------------------------
WORKER_CONCURRENCY=5
WORKER_QUEUE_NAME=integrax-tasks
LOG_LEVEL=info
NODE_ENV=development
