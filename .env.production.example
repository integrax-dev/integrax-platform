# IntegraX Production Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# REQUIRED - Platform will not start without these
# ============================================

# Authentication
JWT_SECRET=                           # Generate: openssl rand -hex 64
CREDENTIAL_ENCRYPTION_KEY=            # Generate: openssl rand -hex 32

# Database
DATABASE_URL=postgresql://user:password@host:5432/integrax
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=integrax

# Redis (Cache, Rate Limiting, PubSub)
REDIS_URL=redis://user:password@host:6379

# Kafka (Event Bus)
KAFKA_BROKERS=broker1:9092,broker2:9092
KAFKA_CLIENT_ID=integrax-production
KAFKA_SASL_USERNAME=                  # If using SASL auth
KAFKA_SASL_PASSWORD=                  # If using SASL auth

# Temporal (Workflows)
TEMPORAL_ADDRESS=temporal.your-domain.com:7233
TEMPORAL_NAMESPACE=production
TEMPORAL_TASK_QUEUE=integrax-workflows

# HashiCorp Vault (Secrets Management)
VAULT_ADDR=https://vault.your-domain.com:8200
VAULT_TOKEN=                          # Use AppRole in production

# ============================================
# AI / LLM
# ============================================

ANTHROPIC_API_KEY=                    # From console.anthropic.com

# ============================================
# CONNECTORS - Fill in only what you use
# ============================================

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# AFIP (Argentina)
AFIP_CUIT=                            # Your CUIT number (no dashes)
AFIP_CERT_PATH=/secrets/afip/cert.crt # Path to certificate
AFIP_KEY_PATH=/secrets/afip/key.key   # Path to private key
AFIP_ENVIRONMENT=production           # production | testing

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Email/SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=IntegraX

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS=            # Base64 encoded service account JSON
GOOGLE_SHEETS_SPREADSHEET_ID=

# Contabilium (Argentina ERP)
CONTABILIUM_CLIENT_ID=
CONTABILIUM_CLIENT_SECRET=

# ============================================
# OBSERVABILITY
# ============================================

# Prometheus (metrics are scraped, not pushed)
METRICS_PORT=9090

# Grafana
GRAFANA_ADMIN_PASSWORD=

# Alertmanager
ALERTMANAGER_SLACK_WEBHOOK=           # For Slack notifications
ALERTMANAGER_PAGERDUTY_KEY=           # For PagerDuty

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=integrax

# ============================================
# APPLICATION
# ============================================

NODE_ENV=production
LOG_LEVEL=info                        # debug | info | warn | error
PORT=3000
WS_PORT=3003

# CORS
CORS_ORIGIN=https://admin.your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000            # 1 minute
RATE_LIMIT_MAX_REQUESTS=100           # per window

# ============================================
# OPTIONAL - Enterprise Features
# ============================================

# SSO / OIDC
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# S3-compatible storage (for file uploads)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=integrax-uploads
S3_REGION=us-east-1
