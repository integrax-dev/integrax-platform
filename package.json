{
  "name": "integrax-oss",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Integration Platform - Open Source",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:worker": "pnpm --filter @integrax/worker dev",
    "dev:temporal": "pnpm --filter @integrax/temporal-workflows dev",
    "dev:kafka-consumer": "pnpm --filter @integrax/kafka-consumer dev",
    "test": "pnpm -r test",
    "test:real": "tsx scripts/test-real.ts",
    "test:integration": "tsx scripts/test-integration.ts",
    "verify:services:live": "tsx scripts/verify-service-reality.ts",
    "verify:surface": "tsx scripts/verify-integration-surface.ts",
    "test:surface:unit": "tsx --test scripts/__tests__/verify-integration-surface.test.ts",
    "quality:gate": "pnpm -C apps/admin-panel run lint:strict && pnpm -C apps/admin-panel run typecheck && pnpm -C contracts/ts run lint && pnpm run test:surface:unit && pnpm run validate:services",
    "simulate:payment": "tsx scripts/simulate-payment.ts",
    "stress-test": "tsx scripts/stress-test.ts",
    "learn-api": "tsx scripts/learn-api.ts",
    "validate:services": "tsx scripts/validate-service-registry.ts",
    "lint": "pnpm -r lint",
    "docker:mvp": "docker compose -f infra/docker-compose/mvp/docker-compose.yml up -d",
    "docker:mvp:down": "docker compose -f infra/docker-compose/mvp/docker-compose.yml down",
    "docker:mvp:logs": "docker compose -f infra/docker-compose/mvp/docker-compose.yml logs -f",
    "docker:enterprise": "docker compose -f infra/docker-compose/enterprise/docker-compose.yml up -d",
    "docker:enterprise:down": "docker compose -f infra/docker-compose/enterprise/docker-compose.yml down",
    "docker:enterprise:logs": "docker compose -f infra/docker-compose/enterprise/docker-compose.yml logs -f",
    "setup:debezium": "tsx scripts/setup-debezium.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "node-vault": "^0.10.2",
    "pg": "^8.11.3",
    "tsx": "^4.6.2",
    "typescript": "^5.3.0",
    "yaml": "^2.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
